{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@app/shared": ["${configDir}/../../packages/shared/src/index.ts"]
    }
    
  },
  
  "exclude": ["node_modules"]
}
